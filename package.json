{
  "name": "mm-studio-design",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n site,studio -c magenta,green --kill-others-on-fail \"npm run dev:site\" \"npm run dev:studio\"",
    "dev:site": "next dev",
    "dev:studio": "cd studio && npm run dev -- --port 3333",
    "build": "npm run build:site && npm run build:studio",
    "build:site": "next build",
    "build:studio": "cd studio && npm run build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@fontsource-variable/bodoni-moda": "^5.2.7",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.1.0",
    "@portabletext/react": "^6.2.0",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@sanity/image-url": "^2.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.12.5",
    "lenis": "^1.1.20",
    "lucide-react": "^0.471.0",
    "next": "16.2.6",
    "next-sanity": "^12.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.2.5",
    "typescript": "^5"
  }
}
