# ---------- Sanity ----------

# Public (exposed to the browser)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Server-only
# Required for the /api/revalidate webhook — any long random string, also pasted into
# the Sanity dashboard webhook "Secret" field.
SANITY_REVALIDATE_SECRET=

# Optional — only needed if you want to read drafts from server components
SANITY_READ_TOKEN=

# One-time use — only needed for scripts/migrate-to-sanity.ts. Create at:
# sanity.io → Project → API → Tokens → Add API token (Editor role).
# Remove after migration completes.
SANITY_WRITE_TOKEN=

# Set to "1" only during local development if you want builds to succeed
# without Sanity configured (the marketing pages will fall back to lib/content.ts).
SANITY_ALLOW_MISSING_ENV=1
